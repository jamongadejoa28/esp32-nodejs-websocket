{
  "__inputs": [
    {
      "name": "DS_MYSQL",
      "label": "MySQL (NAS)",
      "description": "MySQL 5.6 on NAS – select your data source here",
      "type": "datasource",
      "pluginId": "mysql",
      "pluginName": "MySQL"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "mysql", "name": "MySQL", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "title": "Air Quality – JSD-BH-312-002",
  "uid": "airquality01",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "timezone": "browser",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "PM 농도 (GRIMM) – μg/m³",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": { "unit": "µg/m³", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT CONVERT_TZ(recorded_at, '+09:00', '+00:00') AS time, pm1_grimm AS 'PM1.0', pm25_grimm AS 'PM2.5', pm10_grimm AS 'PM10' FROM pm_sensor_data WHERE $__timeFilter(recorded_at) ORDER BY recorded_at ASC",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "PM 농도 (TSI) – μg/m³",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": { "unit": "µg/m³", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT CONVERT_TZ(recorded_at, '+09:00', '+00:00') AS time, pm1_tsi AS 'PM1.0', pm25_tsi AS 'PM2.5', pm10_tsi AS 'PM10' FROM pm_sensor_data WHERE $__timeFilter(recorded_at) ORDER BY recorded_at ASC",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "입자 수 (pcs / 0.1 L)",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1 } }
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT CONVERT_TZ(recorded_at, '+09:00', '+00:00') AS time, cnt_0p3 AS '>0.3µm', cnt_0p5 AS '>0.5µm', cnt_1p0 AS '>1.0µm', cnt_2p5 AS '>2.5µm', cnt_5p0 AS '>5.0µm', cnt_10 AS '>10µm' FROM pm_sensor_data WHERE $__timeFilter(recorded_at) ORDER BY recorded_at ASC",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "현재 PM2.5 (GRIMM)",
      "gridPos": { "x": 0, "y": 16, "w": 4, "h": 4 },
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "µg/m³",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 35,   "color": "yellow" },
              { "value": 75,   "color": "orange" },
              { "value": 150,  "color": "red" }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT CONVERT_TZ(recorded_at, '+09:00', '+00:00') AS time, pm25_grimm AS value FROM pm_sensor_data ORDER BY recorded_at DESC LIMIT 1",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "현재 PM10 (GRIMM)",
      "gridPos": { "x": 4, "y": 16, "w": 4, "h": 4 },
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "µg/m³",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 80,  "color": "yellow" },
              { "value": 150, "color": "orange" },
              { "value": 300, "color": "red" }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT CONVERT_TZ(recorded_at, '+09:00', '+00:00') AS time, pm10_grimm AS value FROM pm_sensor_data ORDER BY recorded_at DESC LIMIT 1",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "현재 PM1.0 (GRIMM)",
      "gridPos": { "x": 8, "y": 16, "w": 4, "h": 4 },
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": { "defaults": { "unit": "µg/m³" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT CONVERT_TZ(recorded_at, '+09:00', '+00:00') AS time, pm1_grimm AS value FROM pm_sensor_data ORDER BY recorded_at DESC LIMIT 1",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "최근 데이터 수신",
      "gridPos": { "x": 12, "y": 16, "w": 4, "h": 4 },
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": { "defaults": { "unit": "dateTimeFromNow" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT CONVERT_TZ(recorded_at, '+09:00', '+00:00') AS time, UNIX_TIMESTAMP(recorded_at)*1000 AS value FROM pm_sensor_data ORDER BY recorded_at DESC LIMIT 1",
          "format": "time_series"
        }
      ]
    }
  ]
}
